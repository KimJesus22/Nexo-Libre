# =============================================================================
# Variables de Entorno — NexoLibre
# =============================================================================
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.
# =============================================================================

# ── Supabase (públicas — se exponen al navegador) ──────────────────────────
# Estas variables se incrustan en el bundle del cliente en build time.
# Son seguras de exponer: solo permiten operaciones que RLS autoriza.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable__tu-clave-publica

# ── URL del sitio (para callbacks de auth) ─────────────────────────────────
# En producción, cambia a tu dominio real (p.ej. https://nexolibre.app)
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# ── Runtime (opcionales) ───────────────────────────────────────────────────
# NODE_ENV=production          # Se establece automáticamente en Docker/Vercel
# NEXT_TELEMETRY_DISABLED=1    # Desactivar telemetría de Next.js
