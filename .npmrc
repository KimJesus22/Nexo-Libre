# ═══════════════════════════════════════════════════════════════════════════════
# Configuración de pnpm — NexoLibre
# ═══════════════════════════════════════════════════════════════════════════════

# Usar hoisted para compatibilidad con Next.js
node-linker=hoisted

# Levantar todos los paquetes al root de node_modules
shamefully-hoist=true

# Versión estricta del motor
engine-strict=true
